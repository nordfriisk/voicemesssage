# Twilio credentials
# Get these from https://console.twilio.com
# NOTE: Trial accounts can only call verified numbers.
# Verify your number at: Console → Phone Numbers → Verified Caller IDs
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# Cloudflare R2 credentials
# Setup steps:
#   1. Cloudflare Dashboard → R2 → Create bucket (e.g. "voice-message")
#   2. Enable "Public access" on the bucket → note the public URL
#   3. R2 → Manage R2 API tokens → Create token with "Object Read & Write"
#   4. Add a lifecycle rule on the bucket: delete objects after 1 hour
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=voice-message
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# TTS settings
# Available voices: af_heart, af_bella, af_nicole (American female),
#                   am_adam, am_michael (American male),
#                   bf_emma, bf_isabella (British female),
#                   bm_george, bm_lewis (British male)
# Default: bf_emma (British female voice)
DEFAULT_VOICE=bf_emma